~cut(.x, length(.y))
choices
choices <- map2(sample, all_decisions,
~cut(.x, length(.y)))
choices
# Random choices for each decision with distributions based on a, b and c
choices <- map2(sample, all_decisions,
~cut(.x, length(.y), labels = .y, include.lowest = TRUE)) %>%
bind_rows()
# Random choices for each decision with distributions based on a, b and c
choices <- map2(sample, all_decisions,
~cut(.x, length(.y), labels = .y)) %>%
bind_rows()
