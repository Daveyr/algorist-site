choices <- map2(sample, all_decisions,
~cut(.x, breaks = .y)) #length(.y), labels = .y)) %>%
# Random choices for each decision with distributions based on a, b and c
choices <- map2(sample, all_decisions,
~cut(.x, breaks = .y)) %>% #length(.y), labels = .y)) %>%
bind_rows()
choices
